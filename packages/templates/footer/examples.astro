---
/**
 * Footer Examples
 *
 * This file demonstrates all footer variants with sample data
 * You can copy and modify these examples for your own use
 */

import Footer from './Footer.astro';

// Sample data - customize for your needs
const sampleData = {
  companyName: 'Stampede Auto',
  tagline: 'Award-winning, family owned car dealership',
  phone: '(403) 888-8174',
  email: 'contact@stampedeauto.com',
  address: '2520 Centre Ave, Calgary, AB T2A 2L2',
  hours: [
    { day: 'Monday - Friday', time: '9:00 AM – 8:00 PM' },
    { day: 'Saturday', time: '9:00 AM – 7:30 PM' },
    { day: 'Sunday', time: 'Closed' },
  ],
  links: [
    { label: 'Inventory', href: '/inventory' },
    { label: 'About', href: '/about' },
    { label: 'Contact', href: '/contact' },
    { label: 'FAQ', href: '/faq' },
    { label: 'Blog', href: '/blog' },
    { label: 'Terms', href: '/terms' },
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Financing', href: '/financing' },
  ],
  socialLinks: [
    { platform: 'Facebook', href: 'https://facebook.com/stampedeauto' },
    { platform: 'Twitter', href: 'https://twitter.com/AutoStampede' },
    { platform: 'Instagram', href: 'https://instagram.com/stampede_auto' },
    { platform: 'YouTube', href: 'https://youtube.com/channel/UC5lkHQJc-LNNMmWipjBxfHA' },
    { platform: 'LinkedIn', href: 'https://linkedin.com/company/stampede-auto' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Footer Examples</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell,
          sans-serif;
      }

      .demo-section {
        margin-bottom: 4rem;
      }

      .demo-header {
        background-color: #f8f9fa;
        padding: 2rem;
        text-align: center;
        border-bottom: 2px solid #e0e0e0;
      }

      .demo-header h2 {
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
        color: #1a1a1a;
      }

      .demo-header p {
        color: #666;
        font-size: 1rem;
      }

      .spacer {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-size: 2rem;
        font-weight: bold;
        text-align: center;
        padding: 2rem;
      }
    </style>
  </head>
  <body>
    <!-- Classic Footer Demo -->
    <div class="demo-section">
      <div class="demo-header">
        <h2>Classic Footer</h2>
        <p>Multi-column layout with complete business information</p>
      </div>
      <div class="spacer">Scroll down to see Classic Footer</div>
      <Footer variant="classic" {...sampleData} showBadge={true} />
    </div>

    <!-- Minimal Footer Demo -->
    <div class="demo-section">
      <div class="demo-header">
        <h2>Minimal Footer</h2>
        <p>Clean and simple design for modern sites</p>
      </div>
      <div class="spacer">Scroll down to see Minimal Footer</div>
      <Footer
        variant="minimal"
        companyName={sampleData.companyName}
        links={sampleData.links.slice(0, 4)}
        socialLinks={sampleData.socialLinks.slice(0, 3)}
      />
    </div>

    <!-- Newsletter Footer Demo -->
    <div class="demo-section">
      <div class="demo-header">
        <h2>Newsletter Footer</h2>
        <p>Engagement-focused with newsletter signup</p>
      </div>
      <div class="spacer">Scroll down to see Newsletter Footer</div>
      <Footer
        variant="newsletter"
        companyName={sampleData.companyName}
        tagline="Stay updated with the latest offers"
        phone={sampleData.phone}
        email={sampleData.email}
        links={sampleData.links.slice(0, 6)}
        socialLinks={sampleData.socialLinks.slice(0, 4)}
      />
    </div>

    <!-- Compact Footer Demo -->
    <div class="demo-section">
      <div class="demo-header">
        <h2>Compact Footer</h2>
        <p>Space-efficient two-column layout</p>
      </div>
      <div class="spacer">Scroll down to see Compact Footer</div>
      <Footer
        variant="compact"
        companyName={sampleData.companyName}
        tagline={sampleData.tagline}
        phone={sampleData.phone}
        email={sampleData.email}
        links={sampleData.links.slice(0, 5)}
        socialLinks={sampleData.socialLinks.slice(0, 3)}
      />
    </div>
  </body>
</html>
