---
/**
 * Compact Footer - Two-column layout
 * Features: Compact design with essential info
 */

export interface Props {
  companyName: string;
  tagline?: string;
  phone?: string;
  email?: string;
  links?: Array<{ label: string; href: string }>;
  socialLinks?: Array<{ platform: string; href: string }>;
}

const {
  companyName,
  tagline = 'Quality service you can trust',
  phone,
  email,
  links = [],
  socialLinks = [],
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class="footer-compact">
  <div class="footer-main">
    <div class="footer-container">
      <div class="footer-grid">
        <!-- Left Column: Company Info -->
        <div class="footer-left">
          <h3 class="company-name">{companyName}</h3>
          <p class="tagline">{tagline}</p>

          {
            socialLinks.length > 0 && (
              <div class="social-links">
                {socialLinks.map((social) => (
                  <a
                    href={social.href}
                    class="social-link"
                    aria-label={social.platform}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={social.platform}
                  >
                    <span class="social-icon">{social.platform.charAt(0).toUpperCase()}</span>
                  </a>
                ))}
              </div>
            )
          }
        </div>

        <!-- Right Column: Links & Contact -->
        <div class="footer-right">
          {
            links.length > 0 && (
              <div class="links-section">
                <h4 class="section-heading">Quick Links</h4>
                <nav class="link-grid">
                  {links.map((link) => (
                    <a href={link.href} class="footer-link">
                      {link.label}
                    </a>
                  ))}
                </nav>
              </div>
            )
          }

          {
            (phone || email) && (
              <div class="contact-section">
                <h4 class="section-heading">Get in Touch</h4>
                <ul class="contact-list">
                  {phone && (
                    <li class="contact-item">
                      <svg
                        class="contact-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                      </svg>
                      <a href={`tel:${phone.replace(/[\s\-()]/g, '')}`} class="contact-link">
                        {phone}
                      </a>
                    </li>
                  )}
                  {email && (
                    <li class="contact-item">
                      <svg
                        class="contact-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                      </svg>
                      <a href={`mailto:${email}`} class="contact-link">
                        {email}
                      </a>
                    </li>
                  )}
                </ul>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-container">
      <p class="copyright">© {currentYear} {companyName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer-compact {
    background-color: #2c3e50;
    color: #ecf0f1;
  }

  .footer-main {
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .company-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .tagline {
    font-size: 0.95rem;
    color: #bdc3c7;
    margin: 0;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-link {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #ffffff;
    transition: all 0.2s;
  }

  .social-link:hover {
    background-color: #3498db;
    transform: translateY(-2px);
  }

  .social-icon {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .footer-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .links-section,
  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.85rem;
  }

  .link-grid {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-link {
    color: #bdc3c7;
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.95rem;
  }

  .footer-link:hover {
    color: #3498db;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .contact-icon {
    width: 1.15rem;
    height: 1.15rem;
    color: #95a5a6;
    flex-shrink: 0;
  }

  .contact-link {
    color: #bdc3c7;
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.95rem;
  }

  .contact-link:hover {
    color: #3498db;
  }

  .footer-bottom {
    padding: 1.25rem 0;
  }

  .copyright {
    text-align: center;
    font-size: 0.875rem;
    color: #95a5a6;
    margin: 0;
  }

  /* Mobile Responsive */
  @media (max-width: 992px) {
    .footer-right {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .footer-main {
      padding: 2rem 0;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-right {
      gap: 2rem;
    }

    .company-name {
      font-size: 1.25rem;
    }
  }
</style>
