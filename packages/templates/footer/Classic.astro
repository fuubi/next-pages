---
/**
 * Classic Footer - Multi-column layout
 * Features: Company info, navigation links, hours, contact details
 */

export interface Props {
  companyName: string;
  tagline: string;
  phone?: string;
  email?: string;
  address?: string;
  hours?: Array<{ day: string; time: string }>;
  links?: Array<{ label: string; href: string }>;
  socialLinks?: Array<{ platform: string; href: string }>;
  showBadge?: boolean;
}

const {
  companyName,
  tagline,
  phone,
  email,
  address,
  hours = [],
  links = [],
  socialLinks = [],
  showBadge = false,
} = Astro.props;

const currentYear = new Date().getFullYear();

// Split links into columns (approximately 1/3 each)
const linksPerColumn = Math.ceil(links.length / 3);
const linkColumns = [
  links.slice(0, linksPerColumn),
  links.slice(linksPerColumn, linksPerColumn * 2),
  links.slice(linksPerColumn * 2),
];
---

<footer class="footer-classic">
  <div class="footer-main">
    <div class="footer-container">
      <!-- Company Info Column -->
      <div class="footer-column footer-company">
        <h3 class="footer-heading">{companyName}</h3>
        <p class="footer-tagline">{tagline}</p>

        {
          socialLinks.length > 0 && (
            <div class="social-links">
              {socialLinks.map((social) => (
                <a
                  href={social.href}
                  class="social-link"
                  aria-label={social.platform}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="social-icon">{social.platform.charAt(0).toUpperCase()}</span>
                </a>
              ))}
            </div>
          )
        }

        {
          showBadge && (
            <div class="badge">
              <div class="badge-placeholder">Certified Business</div>
            </div>
          )
        }
      </div>

      <!-- Links Columns -->
      {
        linkColumns
          .filter((col) => col.length > 0)
          .map((column) => (
            <div class="footer-column footer-links">
              <h4 class="footer-subheading">Quick Links</h4>
              <ul class="link-list">
                {column.map((link) => (
                  <li>
                    <a href={link.href} class="footer-link">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
      }

      <!-- Hours Column -->
      {
        hours.length > 0 && (
          <div class="footer-column footer-hours">
            <h4 class="footer-subheading">Business Hours</h4>
            <ul class="hours-list">
              {hours.map((schedule) => (
                <li class="hours-item">
                  <span class="hours-day">{schedule.day}:</span>
                  <span class="hours-time">{schedule.time}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Contact Column -->
      <div class="footer-column footer-contact">
        <h4 class="footer-subheading">Contact Us</h4>
        <ul class="contact-list">
          {
            phone && (
              <li class="contact-item">
                <svg
                  class="contact-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                </svg>
                <a href={`tel:${phone.replace(/[\s\-()]/g, '')}`} class="contact-link">
                  {phone}
                </a>
              </li>
            )
          }
          {
            email && (
              <li class="contact-item">
                <svg
                  class="contact-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                </svg>
                <a href={`mailto:${email}`} class="contact-link">
                  {email}
                </a>
              </li>
            )
          }
          {
            address && (
              <li class="contact-item">
                <svg
                  class="contact-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span class="contact-text">{address}</span>
              </li>
            )
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-container">
      <p class="copyright">© {currentYear} {companyName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer-classic {
    background-color: var(--color-footer-bg);
    color: var(--color-footer-text);
  }

  .footer-main {
    padding: var(--space-16) 0 var(--space-8);
    border-bottom: var(--border-width) solid var(--color-footer-border);
  }

  .footer-container {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-10);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-heading {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-inverse);
    margin: 0 0 var(--space-2);
  }

  .footer-tagline {
    font-size: var(--font-size-base);
    color: var(--color-footer-text-secondary);
    line-height: var(--line-height-normal);
    margin: 0 0 var(--space-4);
  }

  .footer-subheading {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-inverse);
    margin: 0 0 var(--space-4);
  }

  .link-list,
  .hours-list,
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    color: var(--color-footer-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    font-size: var(--font-size-base);
  }

  .footer-link:hover {
    color: var(--color-footer-link-hover);
  }

  .hours-item {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--font-size-sm);
  }

  .hours-day {
    color: var(--color-text-inverse);
    font-weight: var(--font-weight-medium);
  }

  .hours-time {
    color: var(--color-footer-text-secondary);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .contact-icon {
    width: var(--icon-sm);
    height: var(--icon-sm);
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .contact-link,
  .contact-text {
    color: var(--color-footer-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    font-size: var(--font-size-base);
  }

  .contact-link:hover {
    color: var(--color-footer-link-hover);
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .social-link {
    width: var(--space-10);
    height: var(--space-10);
    border-radius: var(--border-radius-full);
    background-color: var(--color-glass-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-text-inverse);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    background-color: var(--color-hover-bg-strong);
    transform: translateY(-2px);
  }

  .social-icon {
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
  }

  .badge {
    margin-top: var(--space-6);
  }

  .badge-placeholder {
    background-color: var(--color-glass-bg);
    border: var(--border-width) solid var(--color-glass-border);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--border-radius-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-inverse);
    text-align: center;
  }

  .footer-bottom {
    padding: var(--space-6) 0;
  }

  .copyright {
    text-align: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    margin: 0;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-main {
      padding: 3rem 0 1.5rem;
    }

    .footer-heading {
      font-size: 1.25rem;
    }

    .hours-item {
      font-size: 0.85rem;
    }
  }
</style>
