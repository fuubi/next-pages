---
export interface Props {
  currentLang: string;
  currentPath: string;
  languages: Array<{
    lang: string;
    url: string;
  }>;
}

const { currentLang, currentPath, languages } = Astro.props;
---

<div class="language-switcher">
  {
    languages.map((lang) => (
      <a
        href={lang.url}
        class:list={['lang-link', { active: lang.lang === currentLang }]}
        hreflang={lang.lang}
      >
        {lang.lang.toUpperCase()}
      </a>
    ))
  }
</div>

<style>
  .language-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .lang-link {
    padding: 0.25rem 0.75rem;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .lang-link:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .lang-link.active {
    background: rgba(0, 0, 0, 0.1);
    border-color: currentColor;
    pointer-events: none;
  }
</style>
