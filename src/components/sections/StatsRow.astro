---
import Section from '../site/Section.astro';
import Container from '../site/Container.astro';

export interface Props {
  stats: Array<{
    value: string | number;
    label: string;
  }>;
}

const { stats } = Astro.props;

// Helper to check if value is numeric for counter animation
function isNumeric(value: string | number): boolean {
  if (typeof value === 'number') return true;
  return !isNaN(parseFloat(value.toString().replace(/[^0-9.]/g, '')));
}

function extractNumber(value: string | number): number {
  if (typeof value === 'number') return value;
  const num = parseFloat(value.toString().replace(/[^0-9.]/g, ''));
  return isNaN(num) ? 0 : num;
}
---

<Section variant="dark" spacing="lg">
  <Container>
    <div class="stats-row">
      {
        stats.map((stat) => {
          const isNum = isNumeric(stat.value);
          const numValue = isNum ? extractNumber(stat.value) : 0;
          const suffix = typeof stat.value === 'string' ? stat.value.replace(/[0-9.]/g, '') : '';

          return (
            <div class="stat-item" data-animate="fade">
              <div class="stat-value">
                {isNum ? (
                  <>
                    <span data-counter={numValue.toString()}>0</span>
                    {suffix && <span>{suffix}</span>}
                  </>
                ) : (
                  stat.value
                )}
              </div>
              <div class="stat-label">{stat.label}</div>
            </div>
          );
        })
      }
    </div>
  </Container>
</Section>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .stats-row {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
  }

  .stat-label {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--font-size-5xl);
    }
  }
</style>
