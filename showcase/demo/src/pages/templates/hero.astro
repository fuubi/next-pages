---
import Classic from '@templates/hero/Classic.astro';
import '@shared/styles/global.css';
import '@shared/styles/tokens.css';

const heroVariantData = {
  title: "Hero Template Example",
  subtitle: "This shows how the Classic hero template from packages/templates looks",
  primaryButton: { text: "Get Started", href: "#" },
  secondaryButton: { text: "Learn More", href: "#" }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hero Templates - Showcase</title>
  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, sans-serif;
    }
    header {
      background: var(--color-background-secondary, #f5f5f5);
      padding: 2rem;
      border-bottom: 1px solid var(--color-border, #e0e0e0);
    }
    header h1 {
      margin: 0;
      max-width: 1200px;
      margin: 0 auto;
    }
    .component-showcase {
      margin: 3rem 0;
      padding: 2rem 0;
      border-bottom: 2px solid var(--color-border, #e0e0e0);
    }
    .component-label {
      max-width: 1200px;
      margin: 0 auto 1rem;
      padding: 0 2rem;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--color-primary, #0066cc);
    }
    nav {
      max-width: 1200px;
      margin: 0 auto 1rem;
      padding: 0 2rem;
    }
    nav a {
      color: var(--color-primary, #0066cc);
      text-decoration: none;
    }
    nav a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/">← Back to Home</a> |
      <a href="/templates/footer">Footer Templates</a>
    </nav>
    <h1>🎭 Hero Templates</h1>
    <p style="margin: 0.5rem 0 0; color: var(--color-text-secondary, #666);">
      Pre-built hero section variations from packages/templates
    </p>
  </header>

  <div class="component-showcase">
    <div class="component-label">Classic Hero Template</div>
    <Classic {...heroVariantData} />
  </div>

  <div class="component-label" style="padding: 2rem;">
    <p style="color: var(--color-text-secondary, #666); font-size: 1rem; font-weight: normal;">
      More hero templates can be found in <code>packages/templates/hero/</code>
    </p>
  </div>
</body>
</html>
