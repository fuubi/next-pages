---
/**
 * Minimal Footer - Simple, clean design
 * Features: Basic info, social links, copyright
 */

export interface Props {
  companyName: string;
  links?: Array<{ label: string; href: string }>;
  socialLinks?: Array<{ platform: string; href: string }>;
}

const { companyName, links = [], socialLinks = [] } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class="footer-minimal">
  <div class="footer-container">
    <div class="footer-content">
      <!-- Company Name -->
      <div class="company-name">{companyName}</div>

      <!-- Navigation Links -->
      {
        links.length > 0 && (
          <nav class="footer-nav">
            {links.map((link, index) => (
              <>
                <a href={link.href} class="nav-link">
                  {link.label}
                </a>
                {index < links.length - 1 && <span class="separator">•</span>}
              </>
            ))}
          </nav>
        )
      }

      <!-- Social Links -->
      {
        socialLinks.length > 0 && (
          <div class="social-links">
            {socialLinks.map((social) => (
              <a
                href={social.href}
                class="social-link"
                aria-label={social.platform}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="social-text">{social.platform}</span>
              </a>
            ))}
          </div>
        )
      }

      <!-- Copyright -->
      <p class="copyright">© {currentYear} {companyName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer-minimal {
    background-color: var(--color-surface);
    border-top: var(--border-width) solid var(--color-border);
  }

  .footer-container {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    text-align: center;
  }

  .company-name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
  }

  .nav-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-base);
    transition: color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .separator {
    color: var(--color-border-soft);
    font-size: var(--font-size-xs);
  }

  .social-links {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-text);
  }

  .social-text {
    text-transform: capitalize;
  }

  .copyright {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    margin: 0;
  }

  /* Mobile Responsive */
  @media (max-width: 640px) {
    .footer-container {
      padding: var(--space-6) var(--space-4);
    }

    .footer-content {
      gap: var(--space-4);
    }

    .company-name {
      font-size: 1.1rem;
    }

    .footer-nav {
      flex-direction: column;
      gap: 0.5rem;
    }

    .separator {
      display: none;
    }

    .nav-link {
      font-size: 0.9rem;
    }
  }
</style>
