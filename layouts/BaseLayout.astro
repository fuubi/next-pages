---
// Component frontmatter runs on the server at build time
// import { ViewTransitions } from 'astro:transitions';
import AnimationInit from '../components/ui/AnimationInit/v1/AnimationInit.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  lang?: string;
  alternateLanguages?: Array<{ lang: string; url: string }>;
}

const {
  title = 'Astro Marketing Site',
  description = 'Modern static marketing site built with Astro',
  ogImage,
  canonicalURL = Astro.url.href,
  lang = 'en',
  alternateLanguages = [],
} = Astro.props;

const siteTitle = title;
const siteDescription = description;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={siteDescription} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Alternate Language URLs (hreflang) -->
    {alternateLanguages.map((alt) => <link rel="alternate" hreflang={alt.lang} href={alt.url} />)}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:locale" content={lang} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={siteDescription} />
    {ogImage && <meta property="twitter:image" content={ogImage} />}

    <!-- View Transitions: Uncomment when astro:transitions module is available -->
    <!-- <ViewTransitions /> -->
  </head>
  <body>
    <slot />
    <AnimationInit />
  </body>
</html>
