---
/**
 * Carousel - Default carousel component
 * Backward compatibility wrapper with navigation prop
 *
 * @deprecated Consider using CarouselBase with slots or CarouselWithArrows
 */
import CarouselBase from './CarouselBase.astro';
import CarouselArrows from './CarouselArrows.astro';
import CarouselDots from './CarouselDots.astro';

export interface Props {
  slidesPerView?: 1 | 2 | 3 | 4 | 5;
  gap?: 'none' | 'sm' | 'md' | 'lg';
  autoplay?: boolean;
  navigation?: 'arrows' | 'dots' | 'both' | 'none';
  arrowPosition?: 'middle-outside' | 'middle-inside' | 'bottom' | 'top';
}

const {
  slidesPerView = 1,
  gap = 'md',
  autoplay = false,
  navigation = 'both',
  arrowPosition = 'middle-outside',
} = Astro.props;

const showDots = navigation === 'both' || navigation === 'dots';
const showArrows = navigation === 'both' || navigation === 'arrows';
---

<CarouselBase slidesPerView={slidesPerView} gap={gap} autoplay={autoplay}>
  <!-- Default slot: slides -->
  <slot />

  <!-- Conditionally compose arrows -->
  {
    showArrows && (
      <Fragment slot="controls">
        <CarouselArrows position={arrowPosition} />
      </Fragment>
    )
  }

  <!-- Conditionally compose dots -->
  {
    showDots && (
      <Fragment slot="indicators">
        <CarouselDots />
      </Fragment>
    )
  }
</CarouselBase>
