---
import Card from '../Card/Card.astro';

export interface Props {
  // Card pass-through props
  variant?: 'default' | 'hover' | 'bordered' | 'elevated' | 'gradient' | 'glass' | 'outlined';
  padding?: 'sm' | 'md' | 'lg';
  background?: 'white' | 'surface' | 'transparent' | 'primary' | 'secondary';
  radius?: 'none' | 'sm' | 'md' | 'lg' | 'full';
  clickable?: boolean;

  // HorizontalCard specific props
  image: string;
  alt: string;
  imagePosition?: 'left' | 'right';
  imageWidth?: '30' | '40' | '50' | '60';
  objectFit?: 'cover' | 'contain' | 'fill';
  reverseMobile?: boolean;
}

const {
  variant = 'default',
  padding = 'md',
  background,
  radius = 'lg',
  clickable = false,
  image,
  alt,
  imagePosition = 'left',
  imageWidth = '40',
  objectFit = 'cover',
  reverseMobile = false,
} = Astro.props;
---

<Card
  variant={variant}
  padding="none"
  background={background}
  radius={radius}
  clickable={clickable}
>
  <div
    class:list={['horizontal-card', `image-${imagePosition}`, reverseMobile && 'reverse-mobile']}
    style={`--image-width: ${imageWidth}%`}
  >
    <div class="image-wrapper">
      <img src={image} alt={alt} style={`object-fit: ${objectFit}`} />
    </div>

    <div class:list={['content', `padding-${padding}`]}>
      <slot />
    </div>
  </div>
</Card>

<style>
  .horizontal-card {
    display: flex;
    width: 100%;
    height: 100%;
    flex-direction: column;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    min-height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Content padding */
  .padding-sm {
    padding: var(--space-4);
  }

  .padding-md {
    padding: var(--space-6);
  }

  .padding-lg {
    padding: var(--space-8);
  }

  /* Desktop: side-by-side layout */
  @media (min-width: 768px) {
    .horizontal-card {
      flex-direction: row;
    }

    .image-wrapper {
      width: var(--image-width, 40%);
      min-height: auto;
      height: 100%;
    }

    .image-left {
      flex-direction: row;
    }

    .image-right {
      flex-direction: row-reverse;
    }

    /* Border radius adjustments based on position */
    .image-left .image-wrapper img {
      border-top-right-radius: 0;
      border-bottom-right-radius: 0;
    }

    .image-right .image-wrapper img {
      border-top-left-radius: 0;
      border-bottom-left-radius: 0;
    }
  }

  /* Mobile: reverse stack order if requested */
  @media (max-width: 767px) {
    .reverse-mobile {
      flex-direction: column-reverse;
    }

    .image-wrapper:first-child img {
      border-top-left-radius: inherit;
      border-top-right-radius: inherit;
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
    }

    .reverse-mobile .image-wrapper:first-child img {
      border-top-left-radius: 0;
      border-top-right-radius: 0;
      border-bottom-left-radius: inherit;
      border-bottom-right-radius: inherit;
    }
  }
</style>
