---
import Card from '../Card/Card.astro';

export interface Props {
  // Card pass-through props
  variant?: 'default' | 'hover' | 'bordered' | 'elevated' | 'gradient' | 'glass' | 'outlined';
  padding?: 'sm' | 'md' | 'lg';
  background?: 'white' | 'surface' | 'transparent' | 'primary' | 'secondary';
  radius?: 'none' | 'sm' | 'md' | 'lg' | 'full';
  clickable?: boolean;

  // ImageCard specific props
  image: string;
  alt: string;
  imagePosition?: 'top' | 'bottom';
  imageHeight?: 'sm' | 'md' | 'lg' | 'auto';
  objectFit?: 'cover' | 'contain' | 'fill';
}

const {
  variant = 'default',
  padding = 'md',
  background,
  radius = 'lg',
  clickable = false,
  image,
  alt,
  imagePosition = 'top',
  imageHeight = 'md',
  objectFit = 'cover',
} = Astro.props;
---

<Card
  variant={variant}
  padding="none"
  background={background}
  radius={radius}
  clickable={clickable}
>
  <div class:list={['image-card', `image-${imagePosition}`]}>
    {
      imagePosition === 'top' && (
        <div class:list={['image-wrapper', `height-${imageHeight}`]}>
          <img src={image} alt={alt} style={`object-fit: ${objectFit}`} />
        </div>
      )
    }

    <div class:list={['content', `padding-${padding}`]}>
      <slot />
    </div>

    {
      imagePosition === 'bottom' && (
        <div class:list={['image-wrapper', `height-${imageHeight}`]}>
          <img src={image} alt={alt} style={`object-fit: ${objectFit}`} />
        </div>
      )
    }
  </div>
</Card>

<style>
  .image-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Image height variants */
  .height-sm {
    height: 150px;
  }

  .height-md {
    height: 200px;
  }

  .height-lg {
    height: 300px;
  }

  .height-auto {
    height: auto;
  }

  /* Content padding */
  .content {
    flex: 1;
  }

  .padding-sm {
    padding: var(--space-4);
  }

  .padding-md {
    padding: var(--space-6);
  }

  .padding-lg {
    padding: var(--space-8);
  }

  /* Image position variants */
  .image-top {
    flex-direction: column;
  }

  .image-bottom {
    flex-direction: column-reverse;
  }

  /* Ensure first/last child radius matches card */
  .image-wrapper:first-child img {
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
  }

  .image-wrapper:last-child img {
    border-bottom-left-radius: inherit;
    border-bottom-right-radius: inherit;
  }
</style>
