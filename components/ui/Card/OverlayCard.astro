---
import Card from '../Card/Card.astro';

export interface Props {
  // Card pass-through props
  variant?: 'default' | 'hover' | 'bordered' | 'elevated' | 'gradient' | 'glass' | 'outlined';
  padding?: 'sm' | 'md' | 'lg';
  radius?: 'none' | 'sm' | 'md' | 'lg' | 'full';
  clickable?: boolean;

  // OverlayCard specific props
  image: string;
  alt: string;
  overlayPosition?: 'top' | 'center' | 'bottom';
  overlayOpacity?: 'light' | 'medium' | 'dark';
  objectFit?: 'cover' | 'contain' | 'fill';
  minHeight?: 'sm' | 'md' | 'lg' | 'xl';
}

const {
  variant = 'default',
  padding = 'md',
  radius = 'lg',
  clickable = false,
  image,
  alt,
  overlayPosition = 'bottom',
  overlayOpacity = 'medium',
  objectFit = 'cover',
  minHeight = 'md',
} = Astro.props;
---

<Card
  variant={variant}
  padding="none"
  background="transparent"
  radius={radius}
  clickable={clickable}
>
  <div class:list={['overlay-card', `min-height-${minHeight}`]}>
    <div class="image-wrapper">
      <img src={image} alt={alt} style={`object-fit: ${objectFit}`} />
      <div class:list={['overlay', `opacity-${overlayOpacity}`]}></div>
    </div>

    <div class:list={['content', `position-${overlayPosition}`, `padding-${padding}`]}>
      <slot />
    </div>
  </div>
</Card>

<style>
  .overlay-card {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Min height variants */
  .min-height-sm {
    min-height: 250px;
  }

  .min-height-md {
    min-height: 350px;
  }

  .min-height-lg {
    min-height: 450px;
  }

  .min-height-xl {
    min-height: 550px;
  }

  .image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Overlay for darkening the image */
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
  }

  .opacity-light .overlay {
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  }

  .opacity-medium .overlay {
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
  }

  .opacity-dark .overlay {
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
  }

  /* Content overlay */
  .content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
    color: white;
  }

  /* Content padding */
  .padding-sm {
    padding: var(--space-4);
  }

  .padding-md {
    padding: var(--space-6);
  }

  .padding-lg {
    padding: var(--space-8);
  }

  /* Content position variants */
  .position-top {
    justify-content: flex-start;
  }

  .position-center {
    justify-content: center;
  }

  .position-bottom {
    justify-content: flex-end;
  }

  /* Ensure text is readable */
  .content :global(h1),
  .content :global(h2),
  .content :global(h3),
  .content :global(h4),
  .content :global(h5),
  .content :global(h6),
  .content :global(p) {
    color: inherit;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }
</style>
