---
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Container from '@shared/components/site/Container/Container.astro';
import Section from '@shared/components/site/Section/Section.astro';
import Card from '@shared/components/ui/Card/Card.astro';
import Button from '@shared/components/ui/Button/Button.astro';
import Badge from '@shared/components/ui/Badge/Badge.astro';
import Accordion from '@shared/components/ui/Accordion/Accordion.astro';
import Input from '@shared/components/ui/Input/Input.astro';

const alternateLanguages: { lang: string; url: string }[] = [];
---

<BaseLayout
  title="UI Components Showcase"
  description="Buttons, Badges, Forms, and other UI elements"
  lang="en"
  alternateLanguages={alternateLanguages}
>
  <Section variant="default" spacing="lg">
    <Container>
      <div class="showcase-header">
        <h1>UI Components</h1>
        <p class="subtitle">Buttons, badges, forms, and other interactive UI elements</p>
      </div>
    </Container>
  </Section>

  <!-- Button Component -->
  <Section variant="surface" spacing="lg">
    <Container>
      <div class="component-section">
        <h2 id="button">Button Component</h2>
        <p class="description">Flexible button component with multiple variants and sizes</p>

        <h3 class="subsection-title">Variants</h3>
        <div class="button-showcase">
          <Button variant="primary">Primary Button</Button>
          <Button variant="secondary">Secondary Button</Button>
          <Button variant="outline">Outline Button</Button>
        </div>

        <h3 class="subsection-title">Sizes</h3>
        <div class="button-showcase">
          <Button variant="primary" size="sm">Small</Button>
          <Button variant="primary" size="md">Medium</Button>
          <Button variant="primary" size="lg">Large</Button>
        </div>

        <h3 class="subsection-title">With Icons/Emojis</h3>
        <div class="button-showcase">
          <Button variant="primary">
            <span>📞 Call Now</span>
          </Button>
          <Button variant="secondary">
            <span>📧 Email Us</span>
          </Button>
          <Button variant="outline">
            <span>📍 Get Directions</span>
          </Button>
        </div>

        <h3 class="subsection-title">As Links</h3>
        <div class="button-showcase">
          <Button variant="primary" href="#contact">Link Button</Button>
          <Button variant="secondary" href="#services">Secondary Link</Button>
          <Button variant="outline" href="#about">Outline Link</Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Badge Component -->
  <Section variant="default" spacing="lg">
    <Container>
      <div class="component-section">
        <h2 id="badge">Badge Component</h2>
        <p class="description">Small status indicators and labels for categorization</p>

        <h3 class="subsection-title">Variants</h3>
        <div class="badge-showcase">
          <Badge variant="primary">Primary</Badge>
          <Badge variant="secondary">Secondary</Badge>
          <Badge variant="success">Success</Badge>
          <Badge variant="warning">Warning</Badge>
          <Badge variant="error">Error</Badge>
        </div>

        <h3 class="subsection-title">Usage Examples</h3>
        <div class="usage-grid">
          <Card variant="bordered" padding="md">
            <div class="flex-between">
              <h4>Special Offer</h4>
              <Badge variant="warning">New</Badge>
            </div>
            <p>Winter tire package with installation</p>
          </Card>

          <Card variant="bordered" padding="md">
            <div class="flex-between">
              <h4>Service Status</h4>
              <Badge variant="success">Completed</Badge>
            </div>
            <p>Your vehicle is ready for pickup</p>
          </Card>

          <Card variant="bordered" padding="md">
            <div class="flex-between">
              <h4>Appointment</h4>
              <Badge variant="primary">Confirmed</Badge>
            </div>
            <p>Tomorrow at 10:00 AM</p>
          </Card>

          <Card variant="bordered" padding="md">
            <div class="flex-between">
              <h4>Parts Order</h4>
              <Badge variant="warning">Pending</Badge>
            </div>
            <p>Expected delivery in 2-3 days</p>
          </Card>

          <Card variant="bordered" padding="md">
            <div class="flex-between">
              <h4>Payment</h4>
              <Badge variant="error">Overdue</Badge>
            </div>
            <p>Invoice #1234 requires attention</p>
          </Card>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Input Component -->
  <Section variant="surface" spacing="lg">
    <Container>
      <div class="component-section">
        <h2 id="input">Input Component</h2>
        <p class="description">Basic form input fields for text, email, phone, and URL</p>

        <h3 class="subsection-title">Input Types</h3>
        <div class="form-showcase">
          <div class="input-wrapper">
            <label for="name">Full Name</label>
            <Input type="text" name="name" placeholder="Enter your name" />
          </div>

          <div class="input-wrapper">
            <label for="email">Email Address</label>
            <Input type="email" name="email" placeholder="your@email.com" />
          </div>

          <div class="input-wrapper">
            <label for="phone">Phone Number</label>
            <Input type="tel" name="phone" placeholder="+41 12 345 67 89" />
          </div>

          <div class="input-wrapper">
            <label for="website">Website</label>
            <Input type="url" name="website" placeholder="https://example.com" />
          </div>
        </div>

        <h3 class="subsection-title">Required Fields</h3>
        <div class="form-showcase">
          <div class="input-wrapper">
            <label for="required-email">
              Email Address <span class="required-marker">*</span>
            </label>
            <Input type="email" name="required-email" placeholder="your@email.com" required />
          </div>

          <div class="input-wrapper">
            <label for="required-name">
              Full Name <span class="required-marker">*</span>
            </label>
            <Input type="text" name="required-name" placeholder="Enter your name" required />
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Accordion Component -->
  <Section variant="default" spacing="lg">
    <Container>
      <div class="component-section">
        <h2 id="accordion">Accordion Component</h2>
        <p class="description">Collapsible content sections for FAQs, service details, and more</p>

        <h3 class="subsection-title">Service Information</h3>
        <div class="accordion-showcase">
          <Accordion
            id="services"
            question="What services do you offer?"
            answer="We offer comprehensive auto repair services including oil changes, brake service, tire rotation and replacement, engine diagnostics, transmission repair, electrical system repair, and more. Our certified mechanics can handle all makes and models."
          />

          <Accordion
            id="duration"
            question="How long does a typical service take?"
            answer="Service time varies: Oil change takes 30-45 minutes, brake service 1-2 hours, major repairs 2-5 hours, and engine work 1-3 days. We'll provide an accurate estimate when you book."
          />

          <Accordion
            id="warranty"
            question="Do you offer a warranty?"
            answer="Yes! All our work comes with a comprehensive warranty. Parts have manufacturer warranty (1-3 years), labor is covered for 6 months, and brake work includes a 12-month / 20,000 km warranty."
          />

          <Accordion
            id="appointment"
            question="Do I need an appointment?"
            answer="While walk-ins are welcome for basic services, we recommend booking an appointment to ensure we can service your vehicle at your preferred time. You can book online, call us, or stop by the shop."
          />

          <Accordion
            id="payment"
            question="What payment methods do you accept?"
            answer="We accept cash, all major credit cards (Visa, Mastercard, American Express), debit cards, and bank transfers. We also work with most insurance companies."
          />

          <Accordion
            id="brands"
            question="What brands of vehicles do you service?"
            answer="Our certified mechanics are experienced with all makes and models, including European, Asian, and domestic vehicles. We service everything from economy cars to luxury vehicles and light trucks."
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Back to Components -->
  <Section variant="surface" spacing="md">
    <Container>
      <div style="text-align: center;">
        <Button variant="outline" href="/components/"> ← Back to All Components </Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .showcase-header {
    text-align: center;
    max-width: var(--container-md);
    margin: 0 auto var(--space-12);
  }

  .showcase-header h1 {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-4);
  }

  .subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
  }

  .component-section {
    margin-bottom: var(--space-16);
  }

  .component-section h2 {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width-thick) solid var(--color-border);
  }

  .description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .subsection-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
  }

  .button-showcase {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .badge-showcase {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .usage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .flex-between h4 {
    margin: 0;
  }

  .form-showcase {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .input-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-wrapper label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
  }

  .required-marker {
    color: var(--color-error);
  }

  .accordion-showcase {
    max-width: 800px;
    margin-bottom: var(--space-8);
  }
</style>
