---
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Container from '@shared/components/site/Container/Container.astro';
import Section from '@shared/components/site/Section/Section.astro';
import Card from '@shared/components/ui/Card/Card.astro';

const alternateLanguages: { lang: string; url: string }[] = [];

const componentCategories = [
  {
    title: 'Section Components',
    description:
      'Complete page sections: Hero, Features, Services, Testimonials, CTA, FAQ, and more',
    href: '/components/sections',
    icon: '📐',
    componentCount: '10 components',
    examples:
      'Hero, ServiceGrid, FeatureGrid, FeatureSplit, StatsRow, Testimonials, FAQ, LogoCloud, ContactBlock, CTASection',
  },
  {
    title: 'UI Components',
    description: 'Interactive elements: Buttons, Badges, Forms, Inputs, and Accordions',
    href: '/components/ui',
    icon: '🎨',
    componentCount: '4 components',
    examples: 'Button, Badge, Input, Accordion',
  },
  {
    title: 'Cards & Carousels',
    description: 'Versatile card layouts and carousel configurations for galleries and sliders',
    href: '/components/cards',
    icon: '🎴',
    componentCount: '7+ components',
    examples:
      'Card, ImageCard, HorizontalCard, OverlayCard, ReviewCard, PostCard, Carousel, AnimatedCardStack',
  },
];
---

<BaseLayout
  title="Component Library Showcase"
  description="Explore all available components organized by category"
  lang="en"
  alternateLanguages={alternateLanguages}
>
  <Section variant="default" spacing="xl">
    <Container>
      <div class="showcase-header">
        <h1>Component Library</h1>
        <p class="subtitle">
          Explore our complete collection of components, organized by category. Each page includes
          live examples with code you can copy and use.
        </p>
      </div>

      <div class="categories-grid">
        {
          componentCategories.map((category) => (
            <a href={category.href} class="category-link">
              <Card variant="hover" padding="lg" clickable>
                <div class="category-icon">{category.icon}</div>
                <div class="category-header">
                  <h2>{category.title}</h2>
                  <span class="component-count">{category.componentCount}</span>
                </div>
                <p class="category-description">{category.description}</p>
                <div class="component-examples">
                  <small>Includes: {category.examples}</small>
                </div>
                <div class="category-cta">
                  <span class="cta-text">View Components →</span>
                </div>
              </Card>
            </a>
          ))
        }
      </div>
    </Container>
  </Section>

  <!-- Quick Links -->
  <Section variant="surface" spacing="lg">
    <Container>
      <div class="quick-links">
        <h2>Quick Access</h2>
        <p>Jump directly to specific components:</p>

        <div class="links-grid">
          <div class="link-group">
            <h3>Section Components</h3>
            <ul>
              <li><a href="/components/sections#hero">Hero</a></li>
              <li><a href="/components/sections#service-grid">ServiceGrid</a></li>
              <li><a href="/components/sections#feature-grid">FeatureGrid</a></li>
              <li><a href="/components/sections#feature-split">FeatureSplit</a></li>
              <li><a href="/components/sections#stats-row">StatsRow</a></li>
              <li><a href="/components/sections#testimonials">Testimonials</a></li>
              <li><a href="/components/sections#faq">FAQ</a></li>
              <li><a href="/components/sections#logo-cloud">LogoCloud</a></li>
              <li><a href="/components/sections#contact-block">ContactBlock</a></li>
              <li><a href="/components/sections#cta-section">CTASection</a></li>
            </ul>
          </div>

          <div class="link-group">
            <h3>UI Components</h3>
            <ul>
              <li><a href="/components/ui#button">Button</a></li>
              <li><a href="/components/ui#badge">Badge</a></li>
              <li><a href="/components/ui#input">Input</a></li>
              <li><a href="/components/ui#accordion">Accordion</a></li>
            </ul>
          </div>

          <div class="link-group">
            <h3>Cards & Carousels</h3>
            <ul>
              <li><a href="/components/cards#card">Card</a></li>
              <li><a href="/components/cards#layout-cards">Layout Cards</a></li>
              <li><a href="/components/cards#carousel">Carousel</a></li>
              <li><a href="/components/cards#animated-stack">AnimatedCardStack</a></li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Usage Guide -->
  <Section variant="default" spacing="lg">
    <Container>
      <div class="usage-guide">
        <h2>How to Use These Components</h2>
        <div class="steps-grid">
          <Card variant="bordered" padding="lg">
            <div class="step-number">1</div>
            <h3>Browse</h3>
            <p>
              Navigate to a category page to see all components in that category with live examples
            </p>
          </Card>

          <Card variant="bordered" padding="lg">
            <div class="step-number">2</div>
            <h3>Copy</h3>
            <p>
              Find a component you like and copy the example code. All props and variants are
              documented
            </p>
          </Card>

          <Card variant="bordered" padding="lg">
            <div class="step-number">3</div>
            <h3>Customize</h3>
            <p>
              Paste into your page and customize the content, colors, and layout to match your needs
            </p>
          </Card>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Back to Examples -->
  <Section variant="surface" spacing="md">
    <Container>
      <div style="text-align: center;">
        <a href="/" style="color: var(--color-primary); text-decoration: none; font-weight: 500;">
          ← Back to Examples Home
        </a>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .showcase-header {
    text-align: center;
    max-width: var(--container-md);
    margin: 0 auto var(--space-12);
  }

  .showcase-header h1 {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-4);
  }

  .subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-12);
  }

  .category-link {
    text-decoration: none;
    color: inherit;
  }

  .category-icon {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .category-header h2 {
    margin: 0;
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .component-count {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    background: var(--color-background-secondary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--border-radius-full);
  }

  .category-description {
    margin: 0 0 var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .component-examples {
    margin-bottom: var(--space-4);
    padding: var(--space-3);
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-sm);
  }

  .component-examples small {
    font-size: var(--font-size-xs);
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  .category-cta {
    margin-top: var(--space-4);
  }

  .cta-text {
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
  }

  .quick-links {
    text-align: center;
  }

  .quick-links h2 {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-3);
  }

  .quick-links > p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
    text-align: left;
  }

  .link-group h3 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .link-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-group li {
    margin-bottom: var(--space-2);
  }

  .link-group a {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--font-size-base);
    transition: color 0.2s;
  }

  .link-group a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .usage-guide {
    text-align: center;
  }

  .usage-guide h2 {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-8);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-6);
    text-align: center;
  }

  .step-number {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
  }

  .steps-grid h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
  }

  .steps-grid p {
    margin: 0;
    color: var(--color-text-secondary);
  }
</style>
