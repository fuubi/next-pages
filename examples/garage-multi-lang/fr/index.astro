---
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import UtilityBar from '@shared/components/site/UtilityBar/UtilityBar.astro';
import LanguageSwitcher from '@shared/components/site/LanguageSwitcher/LanguageSwitcher.astro';
import Hero from '@shared/components/sections/Hero/Hero.astro';
import ServiceGrid from '@shared/components/sections/ServiceGrid/ServiceGrid.astro';
import ContactBlock from '@shared/components/sections/ContactBlock/ContactBlock.astro';
import Footer from '@shared/components/site/Footer/Footer.astro';
import { getAlternateLanguageUrls } from '../i18n/utils.ts';
import content from './index.json';
// TODO: Import your site-specific theme overrides
// import '@site/styles/tokens.css';
// import '@site/styles/global.css';

const alternateLanguages = getAlternateLanguageUrls('/', 'fr').map(
  (alt: { lang: string; url: string }) => ({
    lang: alt.lang,
    url: `https://garage-mueller.ch${alt.url}`,
  })
);

// Language switcher data (all languages including current)
// Note: When copying to your site, use absolute paths like '/de/', '/fr/', '/it/'
const allLanguages = [
  { lang: 'de', url: '/examples/garage-multi-lang/de/' },
  { lang: 'fr', url: '/examples/garage-multi-lang/fr/' },
  { lang: 'it', url: '/examples/garage-multi-lang/it/' },
];

// Type-safe props from JSON
const heroProps = {
  ...content.hero,
  variant: 'garage' as const,
};

// Footer data
const footerData = {
  variant: 'classic' as const,
  companyName: 'Garage Mueller',
  tagline: 'Votre garage de confiance à Zurich',
  phone: '+41 44 123 45 67',
  email: 'info@garage-mueller.ch',
  address: 'Musterstrasse 123, 8000 Zurich',
  hours: [
    { day: 'Lundi - Vendredi', time: '08:00 - 18:00' },
    { day: 'Samedi', time: '09:00 - 16:00' },
    { day: 'Dimanche', time: 'Fermé' },
  ],
  links: [
    { label: 'À propos', href: '/fr/about' },
    { label: 'Services', href: '/fr/services' },
    { label: 'Contact', href: '/fr/contact' },
    { label: 'FAQ', href: '/fr/faq' },
  ],
  socialLinks: [
    { platform: 'Facebook', href: 'https://facebook.com/garagemueller' },
    { platform: 'Instagram', href: 'https://instagram.com/garagemueller' },
  ],
  showBadge: true,
};
---

<BaseLayout
  title="Garage Mueller - Votre garage à Zurich"
  lang="fr"
  alternateLanguages={alternateLanguages}
>
  <UtilityBar {...content.utilityBar} />
  <LanguageSwitcher currentLang="fr" currentPath="/" languages={allLanguages} />
  <Hero {...heroProps} />
  <ServiceGrid {...content.services} />
  <ContactBlock {...content.contact} />
  <Footer {...footerData} />
</BaseLayout>
