{
  "name": "@garage-sites/monorepo",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "garage": "cd tools/cli && node --experimental-strip-types --experimental-detect-module src/index.ts",
    "dev:cli": "cd tools/cli && npm install",
    "validate": "npm run garage validate"
  },
  "workspaces": [
    "packages/*",
    "sites/*",
    "tools/*"
  ],
  "devDependencies": {
    "astro": "^6.0.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0"
  }
}
